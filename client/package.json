{
    "name": "client",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc -b && vite build",
        "preview": "vite preview",
        "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
        "lint-fix": "eslint . --report-unused-disable-directives --max-warnings 0 --fix",
        "format": "prettier . --write",
        "openapi": "openapi-generator-cli generate -i ../api.yaml -g typescript-fetch -o src/Gen/ --additional-properties=withInterfaces=true",
        "generate": "npm run openapi && npm run lint-fix && npm run format",
        "test": "vitest run"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@fortawesome/fontawesome-svg-core": "^7.3.0",
        "@fortawesome/free-solid-svg-icons": "^7.3.0",
        "@fortawesome/vue-fontawesome": "^3.3.0",
        "@openapitools/openapi-generator-cli": "^2.39.1",
        "@types/debounce": "^1.2.4",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/tsconfig": "^0.9.1",
        "@vueuse/components": "^14.3.0",
        "@vueuse/core": "^14.3.0",
        "buefy": "^3.0.8",
        "bulma": "^1.0.4",
        "debounce": "^3.0.0",
        "esbuild": "^0.28.1",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.9.2",
        "globals": "^17.7.0",
        "jwt-decode": "^4.0.0",
        "pinia": "^3.0.4",
        "prettier": "^3.9.4",
        "sass": "^1.101.0",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.62.1",
        "uuid": "^14.0.1",
        "vite": "^8.1.3",
        "vitest": "^4.1.9",
        "vue": "^3.5.39",
        "vue-router": "^5.1.0",
        "vue-tsc": "^3.3.6"
    }
}
