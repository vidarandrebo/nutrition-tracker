{
    "name": "client",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc -b && vite build",
        "preview": "vite preview",
        "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
        "lint-fix": "eslint . --report-unused-disable-directives --max-warnings 0 --fix",
        "format": "prettier . --write",
        "openapi": "openapi-generator-cli generate -i ../api.yaml -g typescript-fetch -o src/Gen/ --additional-properties=withInterfaces=true",
        "generate": "npm run openapi && npm run lint-fix && npm run format",
        "test": "vitest run"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@fortawesome/vue-fontawesome": "^3.2.0",
        "@openapitools/openapi-generator-cli": "^2.32.0",
        "@types/debounce": "^1.2.4",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/tsconfig": "^0.9.1",
        "@vueuse/components": "^14.3.0",
        "@vueuse/core": "^14.3.0",
        "buefy": "^3.0.5",
        "bulma": "^1.0.4",
        "debounce": "^3.0.0",
        "esbuild": "^0.28.0",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.9.1",
        "globals": "^17.6.0",
        "jwt-decode": "^4.0.0",
        "pinia": "^3.0.4",
        "prettier": "^3.8.3",
        "sass": "^1.99.0",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.59.2",
        "uuid": "^14.0.0",
        "vite": "^8.0.11",
        "vitest": "^4.1.5",
        "vue": "^3.5.34",
        "vue-router": "^5.0.6",
        "vue-tsc": "^3.2.8"
    }
}
